    input:
        short_fasta=str(FASTA_SHORT_DIR / "{sample}.IGH.short.fasta"),
        ok=str(OK_FILE)
    output:
        airr=str(IGBLAST_AIRR_DIR / "{sample}.short.airr.tsv")
    log:
        str(LOG_DIR / "{sample}.igblast_short.airr.log")
    threads: 4
    shell:
        r"""
        set -euo pipefail
        IGDATA="{IGDATA_DIR}" "{IGBLAST_BIN}" \
          -query "{input.short_fasta}" \
          -germline_db_V "{V_DB}" \
          -germline_db_D "{D_DB}" \
          -germline_db_J "{J_DB}" \
