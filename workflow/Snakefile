          -domain_system imgt \
          -organism human \
          -ig_seqtype Ig \
          -num_alignments_V 1 -num_alignments_D 1 -num_alignments_J 1 \
          -outfmt 19 \
          -num_threads {threads} \
          -out "{output.airr}" \
          2> "{log}"
        """


# Remap AIRR sequence_id: short_id -> original long header (10x)
#
rule remap_airr_sequence_id:
    input:
        airr=str(IGBLAST_AIRR_DIR / "{sample}.short.airr.tsv"),
        idmap=str(MAPS_DIR / "{sample}.idmap.tsv")
    output:
        airr=str(IGBLAST_AIRR_DIR / "{sample}.airr.tsv")
    log:
        str(LOG_DIR / "{sample}.remap_airr.log")
    run:
        m = pd.read_csv(input.idmap, sep="\t", header=None, names=["short_id","orig_id"], dtype=str)
        short2orig = dict(zip(m["short_id"], m["orig_id"]))

        df = pd.read_csv(input.airr, sep="\t", dtype=str).fillna("")
        if "sequence_id" not in df.columns:
            raise ValueError(f"AIRR file missing sequence_id column: {input.airr}")

        df["sequence_id"] = df["sequence_id"].map(short2orig).fillna(df["sequence_id"])
        df.to_csv(output.airr, sep="\t", index=False)
        Path(log[0]).write_text(f"Rows: {len(df)}\n")


# Build ChangeO-like minimal DB
#
rule build_changeo_like_db:
    input:
        airr=str(IGBLAST_AIRR_DIR / "{sample}.airr.tsv"),
        short_igblast=str(IGBLAST_RAW_DIR / "{sample}.short.igblast.txt"),
        idmap=str(MAPS_DIR / "{sample}.idmap.tsv")
    output:
        db=str(CHANGEO_DIR / "{sample}.db.tsv")
    log:
        str(LOG_DIR / "{sample}.build_db.log")
    run:
        m = pd.read_csv(input.idmap, sep="\t", header=None, names=["short_id","orig_id"], dtype=str)
        short2orig = dict(zip(m["short_id"], m["orig_id"]))

        junction = {}
        current = None
        want_next = False

        def clean_junc(s: str) -> str:
            s = re.sub(r"\s+", "", s)
            s = s.replace("(", "").replace(")", "").replace("-", "")
            return s

        with open(input.short_igblast, "r", encoding="utf-8", errors="replace") as fh:
            for line in fh:
                line = line.rstrip("\n")
                if line.startswith("# Query:"):
                    current = line.split(":",1)[1].strip()
                    want_next = False
                elif line.startswith("# V-(D)-J junction details"):
                    want_next = True
                elif want_next:
                    if not line.strip():
                        continue
                    parts = line.split("\t")
                    if len(parts) >= 5 and current:
                        junction[current] = clean_junc("".join(parts[:5]))
                    want_next = False

        orig_junction = { short2orig[sid]: j for sid, j in junction.items() if sid in short2orig }

        df = pd.read_csv(input.airr, sep="\t", dtype=str).fillna("")
        prod = df.get("productive","").replace({"True":"T","False":"F","TRUE":"T","FALSE":"F"})
        prod = prod.where(prod.isin(["T","F"]), "F")

        junc = df["sequence_id"].map(orig_junction).fillna("")

        out = pd.DataFrame({
            "SEQUENCE_ID": df.get("sequence_id",""),
            "SEQUENCE_INPUT": df.get("sequence",""),
            "V_CALL": df.get("v_call",""),
            "D_CALL": df.get("d_call",""),
            "J_CALL": df.get("j_call",""),
            "JUNCTION": junc,
            "JUNCTION_LENGTH": junc.str.len().astype(str).replace("0",""),
            "FUNCTIONAL": prod
        })

        out.to_csv(output.db, sep="\t", index=False)
        Path(log[0]).write_text(f"Rows: {len(out)}\n")


# Clean + lowercase (DefineClones needs lowercase fields)
#
rule clean_and_lowercase_db:
    input:
        db=str(CHANGEO_DIR / "{sample}.db.tsv")
    output:
        clean_db=str(CHANGEO_DIR / "{sample}.db.cleaned.lower.tsv")
    log:
        str(LOG_DIR / "{sample}.clean_db.log")
    run:
        df = pd.read_csv(input.db, sep="\t", dtype=str).fillna("")
        df["FUNCTIONAL"] = "T"

        def clean_junction(s: str) -> str:
            s = (s or "").upper()
            s = re.sub(r"[^ACGTN]", "N", s)
            s = re.sub(r"N{2,}", "N", s)
            return s

        df["JUNCTION"] = df["JUNCTION"].map(clean_junction)
        df["JUNCTION_LENGTH"] = df["JUNCTION"].str.len().astype(str).replace("0","")

        df.columns = [c.lower() for c in df.columns]
        df.to_csv(output.clean_db, sep="\t", index=False)
        Path(log[0]).write_text(f"Rows: {len(df)}\n")


# DefineClones
#
rule define_clones:
    input:
        db=str(CHANGEO_DIR / "{sample}.db.cleaned.lower.tsv")
    output:
        clones=str(CLONES_DIR / "{sample}.clones.tsv")
    log:
        str(LOG_DIR / "{sample}.define_clones.log")
    threads: 4
    shell:
        r"""
        set -euo pipefail
        DefineClones.py \
          -d "{input.db}" \
          --act set \
          --model ham \
          --norm len \
          --dist {clone_dist} \
          --nproc {threads} \
          -o "{output.clones}" \
          > "{log}" 2>&1
        """


# Sweep thresholds
#
rule sweep_thresholds:
    input:
        db=str(CHANGEO_DIR / "{sample}.db.cleaned.lower.tsv")
    output:
        summary=str(SWEEP_DIR / "{sample}.threshold_sweep.summary.tsv")
    log:
        str(LOG_DIR / "{sample}.sweep_thresholds.log")
    threads: 4
    run:
        outdir = SWEEP_DIR / wildcards.sample
        outdir.mkdir(parents=True, exist_ok=True)

        rows = []
        import subprocess

        for dist in sweep_dists:
            dist = float(dist)
            tag = f"{wildcards.sample}.dist{dist:.2f}"
            out_clones = outdir / f"{tag}.clones.tsv"
            out_log = outdir / f"{tag}.log"

            cmd = [
                "DefineClones.py",
                "-d", str(input.db),
                "--act", "set",
                "--model", "ham",
                "--norm", "len",
                "--dist", str(dist),
                "--nproc", str(threads),
                "-o", str(out_clones)
            ]

            p = subprocess.run(cmd, capture_output=True, text=True)
            out_log.write_text((p.stdout or "") + "\n" + (p.stderr or ""))

            text = (p.stdout or "") + "\n" + (p.stderr or "")

            def get_int(prefix):
                m = re.search(rf"^\s*{prefix}>\s*([0-9]+)", text, flags=re.M)
                return int(m.group(1)) if m else None

            clones  = get_int("CLONES")
            records = get_int("RECORDS")
            passed  = get_int("PASS")
            failed  = get_int("FAIL")

            if out_clones.exists():
                ddf = pd.read_csv(out_clones, sep="\t", dtype=str).fillna("")
                sizes = ddf.groupby("clone_id").size()
                singleton_frac = float((sizes == 1).sum() / len(sizes)) if len(sizes) else float("nan")
                max_size = int(sizes.max()) if len(sizes) else 0
            else:
                singleton_frac = float("nan")
                max_size = 0

            rows.append({
                "sample": wildcards.sample,
                "dist": dist,
                "clones": clones,
                "records": records,
                "pass": passed,
                "fail": failed,
                "singleton_frac": singleton_frac,
                "max_clone_size": max_size,
                "outfile": str(out_clones),
                "logfile": str(out_log)
            })

        res = pd.DataFrame(rows).sort_values("dist")
        res.to_csv(output.summary, sep="\t", index=False)
        Path(log[0]).write_text("Wrote: " + str(output.summary) + "\n")


# SHM from AIRR (v_identity) + clones
#
rule shm_from_airr:
    input:
        airr=str(IGBLAST_AIRR_DIR / "{sample}.airr.tsv"),
        clones=str(CLONES_DIR / "{sample}.clones.tsv")
    output:
        tsv=str(METRICS_DIR / "{sample}.shm.tsv"),
        summary=str(METRICS_DIR / "{sample}.shm.summary.txt")
    log:
        str(LOG_DIR / "{sample}.shm_from_airr.log")
    conda:
        STATS_ENV
    shell:
        r"""
        set -euo pipefail
        python scripts/compute_shm_from_airr.py \
          --airr "{input.airr}" \
          --clones "{input.clones}" \
          --out_tsv "{output.tsv}" \
          --out_summary "{output.summary}" \
          > "{log}" 2>&1
        """


