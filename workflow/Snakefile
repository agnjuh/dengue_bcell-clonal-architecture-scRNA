############################################
# dengue-scBCR-clonal-architecture pipeline
# 10x VDJ-B -> IGH FASTA -> short FASTA+idmap
# -> IgBLAST short outfmt7 (junction parsing)
# -> IgBLAST short AIRR outfmt19 + id remap
# -> ChangeO-like DB -> DefineClones -> sweep
# -> SHM from AIRR (v_identity) + stats/plots + clone-size vs SHM correlation
# -> Top expanded clones report
# -> MiXCR benchmark vs Immcantation (+ master benchmark summary)
############################################

import re
import pandas as pd
from pathlib import Path

# Project root & workdir
BASEDIR = Path(workflow.basedir).resolve()      # .../workflow
PROJECT_ROOT = BASEDIR.parent                   # project root
workdir: str(PROJECT_ROOT)

# Config
SAMPLES_YML = Path("config/samples.yml")
PARAMS_YML  = Path("config/params.yml")

configfile: str(SAMPLES_YML)
if PARAMS_YML.exists():
    configfile: str(PARAMS_YML)

samples_cfg = config.get("samples", {})

def _parse_samples(samples_cfg):
    out = {}
    if isinstance(samples_cfg, dict):
        for sample, val in samples_cfg.items():
            if isinstance(val, str):
                out[str(sample)] = {"vdj_b": str(val)}
            elif isinstance(val, dict) and "vdj_b" in val:
                out[str(sample)] = {"vdj_b": str(val["vdj_b"])}
            else:
                raise ValueError(
                    "config/samples.yml format must be either\n"
                    "  samples: {H1: 'path'}\n"
                    "or\n"
                    "  samples: {H1: {vdj_b: 'path'}}"
                )
        return out

    if isinstance(samples_cfg, list):
        for row in samples_cfg:
            if not isinstance(row, dict) or "sample" not in row or "vdj_b" not in row:
                raise ValueError("config/samples.yml list elements must contain keys: sample, vdj_b")
            out[str(row["sample"])] = {"vdj_b": str(row["vdj_b"])}
        return out

    raise ValueError("config/samples.yml: `samples` must be a dict or a list.")

SAMPLES = _parse_samples(samples_cfg)
SAMPLE_NAMES = sorted(SAMPLES.keys())

def vdj_b_path(wildcards):
    p = Path(SAMPLES[wildcards.sample]["vdj_b"])
    # Interpret relative paths as relative to PROJECT_ROOT (workdir)
    return str(p if p.is_absolute() else (PROJECT_ROOT / p))

