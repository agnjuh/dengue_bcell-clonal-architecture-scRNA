# check germline
#
rule check_germline_fastas:
    input:
        v=V_FASTA, d=D_FASTA, j=J_FASTA
    output:
        ok=str(OK_FILE)
    log:
        str(LOG_DIR / "check_germline_fastas.log")
    shell:
        r"""
        set -euo pipefail
        test -s "{input.v}"; test -s "{input.d}"; test -s "{input.j}"
        awk 'NF{{print; exit}}' "{input.v}" | grep -q '^>'
        awk 'NF{{print; exit}}' "{input.d}" | grep -q '^>'
        awk 'NF{{print; exit}}' "{input.j}" | grep -q '^>'
        {{
          echo "V file: {input.v}"
          echo "D file: {input.d}"
          echo "J file: {input.j}"
          echo "V records: $(grep -c '^>' "{input.v}")"
          echo "D records: $(grep -c '^>' "{input.d}")"
          echo "J records: $(grep -c '^>' "{input.j}")"
        }} > "{log}"
        echo "OK" > "{output.ok}"
        """


# 10x contigs -> IGH fasta
#
rule tenx_vdjB_to_igh_fasta:
    input:
        ok=str(OK_FILE),
        vdj=vdj_b_path
    output:
        fasta=str(FASTA_DIR / "{sample}.IGH.fasta")
    log:
        str(LOG_DIR / "{sample}.tenx_to_fasta.log")
    conda:
        TENX_ENV
    threads: 1
    shell:
        r"""
        set -euo pipefail
        python "{TENX_SCRIPT}" \
          -i "{input.vdj}" \
          -o "{output.fasta}" \
          --chain IGH \
          --only-productive \
          2> "{log}"
        """


# short fasta + idmap
#
rule make_short_fasta_and_idmap:
    input:
        fasta=str(FASTA_DIR / "{sample}.IGH.fasta")
    output:
        short_fasta=str(FASTA_SHORT_DIR / "{sample}.IGH.short.fasta"),
        idmap=str(MAPS_DIR / "{sample}.idmap.tsv")
    log:
        str(LOG_DIR / "{sample}.make_short_fasta.log")
    run:
        n = 0
        header = None
        seq_parts = []

        with open(input.fasta, "r", encoding="utf-8", errors="replace") as fh, \
             open(output.short_fasta, "w", encoding="utf-8") as fo, \
             open(output.idmap, "w", encoding="utf-8") as fm:

            for line in fh:
                line = line.rstrip("\n")
                if line.startswith(">"):
                    if header is not None:
                        n += 1
                        sid = f"{wildcards.sample}_{n:06d}"
                        fm.write(sid + "\t" + header + "\n")
                        fo.write(">" + sid + "\n" + "".join(seq_parts) + "\n")
                    header = line[1:].strip()
                    seq_parts = []
                else:
                    if line.strip():
                        seq_parts.append(line.strip())

            if header is not None:
                n += 1
                sid = f"{wildcards.sample}_{n:06d}"
                fm.write(sid + "\t" + header + "\n")
                fo.write(">" + sid + "\n" + "".join(seq_parts) + "\n")

        Path(log[0]).write_text(f"Wrote {n} records\n")


# IgBLAST short outfmt7 (junction parsing)
#
rule igblast_short_outfmt7:
    input:
        short_fasta=str(FASTA_SHORT_DIR / "{sample}.IGH.short.fasta"),
        ok=str(OK_FILE)
    output:
        igblast=str(IGBLAST_RAW_DIR / "{sample}.short.igblast.txt")
    log:
        str(LOG_DIR / "{sample}.igblast_short.outfmt7.log")
    threads: 4
    shell:
        r"""
        set -euo pipefail
        IGDATA="{IGDATA_DIR}" "{IGBLAST_BIN}" \
          -query "{input.short_fasta}" \
          -germline_db_V "{V_DB}" \
          -germline_db_D "{D_DB}" \
          -germline_db_J "{J_DB}" \
          -auxiliary_data "{AUX_DATA}" \
          -domain_system imgt \
          -organism human \
          -ig_seqtype Ig \
          -num_alignments_V 1 -num_alignments_D 1 -num_alignments_J 1 \
          -outfmt 7 \
          -num_threads {threads} \
          -out "{output.igblast}" \
          2> "{log}"
        """


