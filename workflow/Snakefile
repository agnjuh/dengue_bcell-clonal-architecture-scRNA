# Top expanded clones report
#
rule top_expanded_clones_report:
    input:
        shm=str(METRICS_DIR / "{sample}.shm.tsv")
    output:
        tsv=str(METRICS_DIR / "{sample}.top_expanded_clones.tsv"),
        summary=str(METRICS_DIR / "{sample}.top_expanded_clones.summary.txt")
    log:
        str(LOG_DIR / "{sample}.top_expanded_clones.log")
    params:
        top_n=TOP_N_EXPANDED
    conda:
        STATS_ENV
    shell:
        r"""
        set -euo pipefail
        python scripts/top_expanded_clones_report.py \
          --shm_tsv "{input.shm}" \
          --out_tsv "{output.tsv}" \
          --out_summary "{output.summary}" \
          --top_n {params.top_n} \
          > "{log}" 2>&1
        """


# MiXCR run from IGH fasta (per sample)
#
rule run_mixcr:
    input:
        fasta=str(FASTA_DIR / "{sample}.IGH.fasta")
    output:
        map_tsv=str(MIXCR_DIR / "{sample}" / "{sample}.mixcr.readId_to_cloneId.tsv"),
        clones_tsv=str(MIXCR_DIR / "{sample}" / "{sample}.mixcr.clones.tsv")
    log:
        str(LOG_DIR / "{sample}.mixcr.log")
    threads: 4
    conda:
        MIXCR_ENV
    params:
        preset=lambda wc: str(MIXCR_PRESET),
        species=lambda wc: str(MIXCR_SPECIES),
        rna_flag=lambda wc: ("--rna" if MIXCR_RNA else ""),
        left_boundary=lambda wc: str(MIXCR_LEFT_BOUNDARY),
        right_mode=lambda wc: str(MIXCR_RIGHT_BOUNDARY_MODE),
        right_anchor=lambda wc: str(MIXCR_RIGHT_BOUNDARY_ANCHOR),
        assemble_by=lambda wc: str(MIXCR_ASSEMBLE_BY),
    shell:
        r"""
        set -euo pipefail
        mkdir -p "{MIXCR_DIR}/{wildcards.sample}"

        python scripts/run_mixcr_from_fasta.py \
          --fasta "{input.fasta}" \
          --outdir "{MIXCR_DIR}/{wildcards.sample}" \
          --threads {threads} \
          --species "{params.species}" \
          --preset "{params.preset}" \
          {params.rna_flag} \
          --left_boundary "{params.left_boundary}" \
          --right_boundary_mode "{params.right_mode}" \
          --right_boundary_anchor "{params.right_anchor}" \
          --assemble_by "{params.assemble_by}" \
          --force \
          --out_map_tsv "{output.map_tsv}" \
          --out_clones_tsv "{output.clones_tsv}" \
          > "{log}" 2>&1

        test -s "{output.map_tsv}"
        test -s "{output.clones_tsv}"
        """


# NEW: MiXCR readId -> sequence_id -> cloneId map (per sample)
#
rule mixcr_sequence_id_to_cloneId:
    input:
        fasta=str(FASTA_DIR / "{sample}.IGH.fasta"),
        readmap=str(MIXCR_DIR / "{sample}" / "{sample}.mixcr.readId_to_cloneId.tsv")
    output:
        seqmap=str(MIXCR_DIR / "{sample}" / "{sample}.mixcr.sequenceId_to_cloneId.tsv")
    log:
        str(LOG_DIR / "{sample}.mixcr.sequenceId_to_cloneId.log")
    run:
        import pandas as pd

        # FASTA headers in order
        seq_ids = []
        with open(input.fasta, "r", encoding="utf-8", errors="replace") as fh:
            for line in fh:
                if line.startswith(">"):
                    seq_ids.append(line[1:].strip())

        fasta_map = pd.DataFrame({
            "readId": list(range(len(seq_ids))),   # MiXCR readId corresponds to FASTA record index
            "sequence_id": seq_ids
        })

        mix = pd.read_csv(input.readmap, sep="\t", dtype=str).fillna("")
        if "readId" not in mix.columns or "cloneId" not in mix.columns:
            raise ValueError(f"Unexpected columns in {input.readmap}: {list(mix.columns)}")

        # normalize types for join
        fasta_map["readId"] = fasta_map["readId"].astype(str)
        mix["readId"] = mix["readId"].astype(str)

        out = fasta_map.merge(mix[["readId", "cloneId"]], on="readId", how="inner")
        out = out[["sequence_id", "cloneId"]]

        out.to_csv(output.seqmap, sep="\t", index=False)
        Path(log[0]).write_text(f"FASTA records: {len(seq_ids)}\nMatched: {len(out)}\n")


# Benchmark MiXCR vs Immcantation (per sample)
#
rule benchmark_mixcr_vs_immcantation:
    input:
        imm=str(CLONES_DIR / "{sample}.clones.tsv"),
        mixmap=str(MIXCR_DIR / "{sample}" / "{sample}.mixcr.sequenceId_to_cloneId.tsv")
    output:
        tsv=str(METRICS_DIR / "{sample}.mixcr_benchmark.tsv"),
        summary=str(METRICS_DIR / "{sample}.mixcr_benchmark.summary.txt")
    log:
        str(LOG_DIR / "{sample}.mixcr_benchmark.log")
    conda:
        STATS_ENV
    shell:
        r"""
        set -euo pipefail
        python scripts/benchmark_mixcr_vs_immcantation.py \
          --sample "{wildcards.sample}" \
          --immcantation_clones_tsv "{input.imm}" \
          --mixcr_map_tsv "{input.mixmap}" \
          --out_tsv "{output.tsv}" \
          --out_summary "{output.summary}" \
          --min_expanded_size {BENCH_MIN_EXP_SIZE} \
          > "{log}" 2>&1
        """


# Master benchmark summary across samples
#
rule mixcr_benchmark_master:
    input:
        expand(str(METRICS_DIR / "{sample}.mixcr_benchmark.summary.txt"), sample=SAMPLE_NAMES)
    output:
        tsv=str(METRICS_DIR / "mixcr_benchmark.master.tsv")
    log:
        str(LOG_DIR / "mixcr_benchmark.master.log")
    run:
        rows = []
        for s in SAMPLE_NAMES:
            p = METRICS_DIR / f"{s}.mixcr_benchmark.summary.txt"
            d = {"sample": s}
            if not p.exists():
                continue
            for line in p.read_text().splitlines():
                if not line.strip():
                    continue
                if "\t" not in line:
                    continue
                k, v = line.split("\t", 1)
                d[k] = v
            rows.append(d)
        df = pd.DataFrame(rows)
        df.to_csv(output.tsv, sep="\t", index=False)
        Path(log[0]).write_text("Wrote: " + str(output.tsv) + "\n")